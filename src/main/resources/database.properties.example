# ============================================================================
# Database connection - PostgreSQL on Neon
# ============================================================================

# JDBC URL must start with jdbc:postgresql://
# In Neon, click "Connection Details" and copy the connection string,
# then prepend "jdbc:" to it.
db.url=jdbc:postgresql://ep-xxxx-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

db.user=neondb_owner
db.password=replace_with_real_password
db.driver=org.postgresql.Driver
